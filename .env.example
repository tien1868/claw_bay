# eBay Claw — copy to .env and adjust
EBAY_CLAW_AGE_THRESHOLD_DAYS_30=30
EBAY_CLAW_AGE_THRESHOLD_DAYS_60=60
EBAY_CLAW_AGE_THRESHOLD_DAYS_75=75
EBAY_CLAW_AGE_THRESHOLD_DAYS_90=90
EBAY_CLAW_AGE_THRESHOLD_DAYS_120=120
EBAY_CLAW_AGE_THRESHOLD_DAYS_180=180
EBAY_CLAW_STALE_RISK_BASE=0.15
EBAY_CLAW_MAX_AUTO_MARKDOWN_PCT=30
EBAY_CLAW_HIGH_VALUE_PRICE_USD=200
EBAY_CLAW_EXECUTION_ENABLED=false
EBAY_CLAW_FIXTURE_PATH=fixtures/sample_listings.json
EBAY_CLAW_REVIEW_QUEUE_PATH=.ebay_claw_review_queue.json
EBAY_CLAW_POLICY_LOG_PATH=.ebay_claw_policy.log
EBAY_CLAW_SYNC_STATE_PATH=.ebay_claw_sync_state.json
EBAY_CLAW_SYNC_HISTORY_PATH=.ebay_claw_sync_history.jsonl
EBAY_CLAW_SYNC_HISTORY_ENABLED=true

# Read-only sold comps (fixture JSON; swap adapter for official sold APIs later)
EBAY_CLAW_COMPS_ENABLED=true
EBAY_CLAW_COMPS_FIXTURE_PATH=fixtures/sold_comps.json
EBAY_CLAW_COMPS_RECENCY_DEFAULT_DAYS=90

# Canonical server-side mode (UI cannot override): fixture | live_read_only | live_guarded_write
EBAY_CLAW_RUNTIME_MODE=fixture

# Live read-only (Inventory API). Use either a short-lived access token OR refresh flow:
EBAY_CLAW_EBAY_ACCESS_TOKEN=
EBAY_CLAW_EBAY_CLIENT_ID=
EBAY_CLAW_EBAY_CLIENT_SECRET=
EBAY_CLAW_EBAY_REFRESH_TOKEN=
EBAY_CLAW_EBAY_USE_SANDBOX=false
EBAY_CLAW_EBAY_MARKETPLACE_ID=EBAY_US

EBAY_CLAW_STRICT_CONFIG=false
EBAY_CLAW_GUARDED_WRITE_ENABLED=false

# Tests / dev only: allow ClawOrchestrator(data_source_override=...) — never in production
EBAY_CLAW_ALLOW_DEV_RUNTIME_OVERRIDE=false

# Cap Inventory API GET calls per sync run (fail-closed partial sync when exceeded)
EBAY_CLAW_API_BUDGET_MAX_CALLS_PER_RUN=500

EBAY_CLAW_POLICY_STRUCTURED_LOG_PATH=.ebay_claw_policy.jsonl
EBAY_CLAW_AUDIT_LOG_PATH=.ebay_claw_audit.jsonl
# Rotate audit log when size exceeds N bytes (0 = never). Chain hash resets on new active file.
EBAY_CLAW_AUDIT_LOG_MAX_BYTES=0
EBAY_CLAW_AUDIT_LOG_ROTATION_KEEP=5
EBAY_CLAW_AUDIT_CHAIN_ENABLED=false
